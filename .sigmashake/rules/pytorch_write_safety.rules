# pytorch_write_safety.rules
# Technology: pytorch | Capability: write

rule pytorch-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_pytorch_PATTERN"
  MESSAGE "Blocked an unsafe pattern in pytorch. Use the recommended best practices for 2025/2026."
}

rule pytorch-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_pytorch_API"
  MESSAGE "You are using an outdated API for pytorch. Please upgrade to the newer API."
}
